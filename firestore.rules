rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function authLookup() {
      return get(/databases/$(database)/documents/authLookup/$(request.auth.uid)).data;
    }

    function myHouseholdId() {
      return authLookup().householdId;
    }

    function myUserId() {
      return authLookup().userId;
    }

    function myRole() {
      return get(/databases/$(database)/documents/users/$(myUserId())).data.role;
    }

    function isOwner()    { return myRole() == 'owner'; }
    function isAdmin()    { return myRole() == 'admin'; }
    function isMember()   { return myRole() == 'member'; }

    function canWrite()   { return isOwner() || isAdmin(); }
    function canAddTx()   { return isOwner() || isAdmin() || isMember(); }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Any signed-in user can read their own profile; household members can
      // read profiles of people in the same household.
      allow read: if isSignedIn() &&
        (userId == myUserId() ||
         get(/databases/$(database)/documents/users/$(userId)).data.householdId == myHouseholdId());
      // Users can only create their own profile document.
      allow create: if isSignedIn() && userId == myUserId();
      // Self-update always allowed. Owners/admins can only update profiles of
      // users within their own household — prevents cross-household tampering.
      allow update: if isSignedIn() && (
        userId == myUserId() ||
        (canWrite() &&
         get(/databases/$(database)/documents/users/$(userId)).data.householdId == myHouseholdId())
      );
      // No client-side deletion — prevents orphaned household data.
      allow delete: if false;
    }

    // ── Households ────────────────────────────────────────────────────────────
    match /households/{householdId} {
      allow read:  if isSignedIn() && householdId == myHouseholdId();
      allow write: if isSignedIn() && householdId == myHouseholdId() && isOwner();

      // ── Accounts ────────────────────────────────────────────────────────────
      match /accounts/{accountId} {
        allow read: if isSignedIn() && householdId == myHouseholdId();
        allow create: if isSignedIn() && householdId == myHouseholdId() && canWrite();
        allow update: if isSignedIn() && householdId == myHouseholdId() &&
          (canWrite() ||
           (isMember() && resource.data.ownerUserId == myUserId()));
        allow delete: if isSignedIn() && householdId == myHouseholdId() && isOwner();
      }

      // ── Transactions ────────────────────────────────────────────────────────
      match /transactions/{txId} {
        allow read: if isSignedIn() && householdId == myHouseholdId();
        // Pin createdByUserId to the caller on create — prevents spoofing.
        allow create: if isSignedIn() && householdId == myHouseholdId() && canAddTx() &&
          request.resource.data.createdByUserId == myUserId();
        // Prevent createdByUserId and ownerUserId from being changed on update.
        allow update: if isSignedIn() && householdId == myHouseholdId() &&
          (canWrite() || resource.data.createdByUserId == myUserId()) &&
          request.resource.data.createdByUserId == resource.data.createdByUserId &&
          request.resource.data.ownerUserId     == resource.data.ownerUserId;
        allow delete: if isSignedIn() && householdId == myHouseholdId() &&
          (isOwner() || resource.data.createdByUserId == myUserId());
      }

      // ── Savings Goals ────────────────────────────────────────────────────────
      match /savingsGoals/{goalId} {
        allow read: if isSignedIn() && householdId == myHouseholdId();
        allow write: if isSignedIn() && householdId == myHouseholdId() && canWrite();
      }

      // ── Bills ────────────────────────────────────────────────────────────────
      // Bills have no createdByUserId; delete is restricted to owners/admins.
      match /bills/{billId} {
        allow read: if isSignedIn() && householdId == myHouseholdId();
        allow create: if isSignedIn() && householdId == myHouseholdId() && canAddTx();
        allow update: if isSignedIn() && householdId == myHouseholdId() &&
          (canWrite() || resource.data.ownerUserId == myUserId());
        allow delete: if isSignedIn() && householdId == myHouseholdId() && canWrite();
      }

      // ── Investments ──────────────────────────────────────────────────────────
      match /investments/{investmentId} {
        allow read: if isSignedIn() && householdId == myHouseholdId();
        allow write: if isSignedIn() && householdId == myHouseholdId() && canWrite();
      }

      // ── Loans ─────────────────────────────────────────────────────────────────
      match /loans/{loanId} {
        allow read: if isSignedIn() && householdId == myHouseholdId();
        allow create: if isSignedIn() && householdId == myHouseholdId() && canWrite();
        allow update: if isSignedIn() && householdId == myHouseholdId() &&
          (canWrite() ||
           (isMember() && resource.data.ownerUserId == myUserId()));
        allow delete: if isSignedIn() && householdId == myHouseholdId() && isOwner();
      }

      // ── Installment Plans ────────────────────────────────────────────────────
      match /installmentPlans/{planId} {
        allow read: if isSignedIn() && householdId == myHouseholdId();
        allow create: if isSignedIn() && householdId == myHouseholdId() && canAddTx();
        allow update: if isSignedIn() && householdId == myHouseholdId() &&
          (canWrite() || resource.data.ownerUserId == myUserId());
        allow delete: if isSignedIn() && householdId == myHouseholdId() && canWrite();
      }

      // ── Installments ─────────────────────────────────────────────────────────
      match /installments/{installmentId} {
        allow read: if isSignedIn() && householdId == myHouseholdId();
        allow create: if isSignedIn() && householdId == myHouseholdId() && canAddTx();
        allow update: if isSignedIn() && householdId == myHouseholdId() && canAddTx();
        allow delete: if isSignedIn() && householdId == myHouseholdId() && canWrite();
      }

      // ── Activity Log ─────────────────────────────────────────────────────────
      // Immutable log; entries must be attributed to the writing user.
      match /activityLog/{entryId} {
        allow read: if isSignedIn() && householdId == myHouseholdId();
        allow create: if isSignedIn() && householdId == myHouseholdId() &&
          request.resource.data.userId == myUserId();
        allow update, delete: if false;
      }

      // ── Budgets ──────────────────────────────────────────────────────────────
      match /budgets/{budgetId} {
        allow read: if isSignedIn() && householdId == myHouseholdId();
        allow write: if isSignedIn() && householdId == myHouseholdId() && canWrite();
      }
    }

    // ── Auth Lookup ───────────────────────────────────────────────────────────
    // Written once during registration; immutable thereafter.
    // Mutable authLookup would allow a user to switch their householdId.
    // Delete is allowed so account deletion can clean up the lookup entry.
    match /authLookup/{uid} {
      allow read:   if isSignedIn() && uid == request.auth.uid;
      allow create: if isSignedIn() && uid == request.auth.uid;
      allow update: if false;
      allow delete: if isSignedIn() && uid == request.auth.uid;
    }

    // ── Invite Codes ─────────────────────────────────────────────────────────
    // Anyone can read (knowing the code string IS the credential).
    // Only household owners/admins can create codes for their own household.
    match /inviteCodes/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.householdId == myHouseholdId() && canWrite();
      allow delete: if isSignedIn() &&
        resource.data.householdId == myHouseholdId() && isOwner();
      allow update: if false;
    }

    // ── Auth Logs ─────────────────────────────────────────────────────────────
    // Write-only immutable audit trail; uid field must match the caller.
    match /authLogs/{logId} {
      allow create: if isSignedIn() &&
        (!request.resource.data.keys().hasAny(["uid"]) ||
         request.resource.data.uid == request.auth.uid) &&
        (!request.resource.data.keys().hasAny(["userId"]) ||
         request.resource.data.userId == myUserId());
      allow read, update, delete: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
